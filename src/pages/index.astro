---
import '../styles/global.css';
import App from '../components/App.jsx';

// Dominio del sitio (sin barra final). og:url / og:image se vuelven
// absolutas automáticamente (requerido por algunas plataformas para
// mostrar el preview). Si cambias a dominio propio, actualízalo aquí
// y en astro.config.mjs.
const SITE_URL = 'https://alex-d-e-v.vercel.app';
const OG_IMAGE = SITE_URL + '/brand/og-image.png';
const OG_TITLE = 'Alex D.E.V. — Full Stack Developer';
const OG_DESC =
  'Portafolio de Alex D.E.V.: desarrollo web, apps, videojuegos y consultoría técnica. Cosmos + Código.';
---

<!doctype html>
<html lang="es" data-font="geist">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" type="image/png" href="/brand/peque-sinfondo.png" />
    <link rel="apple-touch-icon" href="/brand/peque.png" />
    <meta name="theme-color" content="#070B14" />

    <title>Alex D.E.V. — Full Stack Developer</title>
    <meta name="description" content={OG_DESC} />

    {/* Open Graph (WhatsApp, LinkedIn, Facebook, Telegram, Discord) */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={OG_TITLE} />
    <meta property="og:description" content={OG_DESC} />
    <meta property="og:image" content={OG_IMAGE} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {SITE_URL && <meta property="og:url" content={SITE_URL} />}
    <meta property="og:site_name" content="Alex D.E.V." />

    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={OG_TITLE} />
    <meta name="twitter:description" content={OG_DESC} />
    <meta name="twitter:image" content={OG_IMAGE} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Geist+Mono:wght@400;500&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <App client:only="react" />
  </body>
</html>
